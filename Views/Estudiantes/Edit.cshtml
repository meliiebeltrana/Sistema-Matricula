@model ProyectoFinal.Models.Estudiante

@{
    ViewData["Title"] = "Editar estudiante";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h2 class="mb-0">Editar estudiante</h2>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    Modifique la información del estudiante seleccionado.
                </p>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Identificacion"
                               class="form-label">
                        </label>

                        <input asp-for="Identificacion"
                               class="form-control" />

                        <span asp-validation-for="Identificacion"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NombreCompleto"
                               class="form-label">
                        </label>

                        <input asp-for="NombreCompleto"
                               class="form-control" />

                        <span asp-validation-for="NombreCompleto"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Correo"
                               class="form-label">
                        </label>

                        <input asp-for="Correo"
                               class="form-control"
                               type="email" />

                        <span asp-validation-for="Correo"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono"
                               class="form-label">
                        </label>

                        <input asp-for="Telefono"
                               class="form-control" />

                        <span asp-validation-for="Telefono"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaNacimiento"
                               class="form-label">
                        </label>

                        <input asp-for="FechaNacimiento"
                               class="form-control"
                               type="date" />

                        <span asp-validation-for="FechaNacimiento"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CarreraId"
                               class="form-label">
                        </label>

                        <select asp-for="CarreraId"
                                class="form-select"
                                asp-items="ViewBag.CarreraId">

                            <option value="">
                                Seleccione una carrera
                            </option>
                        </select>

                        <span asp-validation-for="CarreraId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Activo"
                               class="form-check-input" />

                        <label asp-for="Activo"
                               class="form-check-label">
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-warning">
                            Guardar cambios
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}