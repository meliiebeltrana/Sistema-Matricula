@model IEnumerable<ProyectoFinal.Models.Docente>

@{
    ViewData["Title"] = "Docentes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Docentes</h1>

        <p class="text-muted">
            Consulte y administre los docentes registrados en el sistema.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Agregar docente
    </a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">

        @TempData["Mensaje"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No hay docentes registrados en el sistema.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Identificación</th>
                    <th>Nombre completo</th>
                    <th>Correo electrónico</th>
                    <th>Especialidad</th>
                    <th>Teléfono</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var docente in Model)
                {
                    <tr>
                        <td>@docente.Identificacion</td>

                        <td>@docente.NombreCompleto</td>

                        <td>
                            <a href="mailto:@docente.Correo">
                                @docente.Correo
                            </a>
                        </td>

                        <td>@docente.Especialidad</td>

                        <td>
                            @if (string.IsNullOrWhiteSpace(docente.Telefono))
                            {
                                <span class="text-muted">
                                    No registrado
                                </span>
                            }
                            else
                            {
                                @docente.Telefono
                            }
                        </td>

                        <td>
                            @if (docente.Activo)
                            {
                                <span class="badge bg-success">
                                    Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Inactivo
                                </span>
                            }
                        </td>

                        <td class="text-center">
                            <a asp-action="Details"
                               asp-route-id="@docente.Id"
                               class="btn btn-info btn-sm">
                                Ver
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@docente.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@docente.Id"
                               class="btn btn-danger btn-sm">
                                Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}