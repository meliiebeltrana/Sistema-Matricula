@model ProyectoFinal.Models.Docente

@{
    ViewData["Title"] = "Agregar docente";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Agregar docente</h2>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    Complete la información para registrar un nuevo docente.
                </p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Identificacion"
                               class="form-label">
                        </label>

                        <input asp-for="Identificacion"
                               class="form-control"
                               placeholder="Ejemplo: 1-1234-5678" />

                        <span asp-validation-for="Identificacion"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NombreCompleto"
                               class="form-label">
                        </label>

                        <input asp-for="NombreCompleto"
                               class="form-control"
                               placeholder="Ingrese el nombre completo" />

                        <span asp-validation-for="NombreCompleto"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Correo"
                               class="form-label">
                        </label>

                        <input asp-for="Correo"
                               class="form-control"
                               type="email"
                               placeholder="docente@universidad.com" />

                        <span asp-validation-for="Correo"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Especialidad"
                               class="form-label">
                        </label>

                        <input asp-for="Especialidad"
                               class="form-control"
                               placeholder="Ejemplo: Desarrollo de software" />

                        <span asp-validation-for="Especialidad"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono"
                               class="form-label">
                        </label>

                        <input asp-for="Telefono"
                               class="form-control"
                               placeholder="Ejemplo: 8888-8888" />

                        <span asp-validation-for="Telefono"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Activo"
                               class="form-check-input" />

                        <label asp-for="Activo"
                               class="form-check-label">
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            Guardar docente
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}