@model ProyectoFinal.Models.Matricula

@{
    ViewData["Title"] = "Registrar matrícula";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Registrar matrícula</h2>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    Seleccione el estudiante y el curso que desea matricular.
                </p>

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="EstudianteId"
                               class="form-label">
                        </label>

                        <select asp-for="EstudianteId"
                                class="form-select"
                                asp-items="ViewBag.EstudianteId">

                            <option value="">
                                Seleccione un estudiante
                            </option>
                        </select>

                        <span asp-validation-for="EstudianteId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CursoId"
                               class="form-label">
                        </label>

                        <select asp-for="CursoId"
                                class="form-select"
                                asp-items="ViewBag.CursoId">

                            <option value="">
                                Seleccione un curso
                            </option>
                        </select>

                        <span asp-validation-for="CursoId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaMatricula"
                               class="form-label">
                        </label>

                        <input asp-for="FechaMatricula"
                               class="form-control"
                               type="date" />

                        <span asp-validation-for="FechaMatricula"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PeriodoAcademico"
                               class="form-label">
                        </label>

                        <input asp-for="PeriodoAcademico"
                               class="form-control"
                               placeholder="Ejemplo: III Cuatrimestre 2026" />

                        <span asp-validation-for="PeriodoAcademico"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Estado"
                               class="form-label">
                        </label>

                        <select asp-for="Estado"
                                class="form-select">

                            <option value="Activa">Activa</option>
                            <option value="Finalizada">Finalizada</option>
                            <option value="Cancelada">Cancelada</option>
                        </select>

                        <span asp-validation-for="Estado"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NotaFinal"
                               class="form-label">
                        </label>

                        <input asp-for="NotaFinal"
                               class="form-control"
                               type="number"
                               min="0"
                               max="100"
                               step="0.01"
                               placeholder="Puede dejarse en blanco" />

                        <span asp-validation-for="NotaFinal"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            Guardar matrícula
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}