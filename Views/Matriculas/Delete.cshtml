@model ProyectoFinal.Models.Matricula

@{
    ViewData["Title"] = "Eliminar matrícula";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h2 class="mb-0">Eliminar matrícula</h2>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    ¿Está seguro de que desea eliminar esta matrícula?
                    Esta acción no se puede deshacer.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">
                        Estudiante
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.Estudiante != null)
                        {
                            @Model.Estudiante.NombreCompleto
                        }
                        else
                        {
                            <span class="text-muted">
                                Estudiante no disponible
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">
                        Curso
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.Curso != null)
                        {
                            <span>
                                @Model.Curso.Codigo - @Model.Curso.Nombre
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">
                                Curso no disponible
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">
                        Carrera
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.Curso?.Carrera != null)
                        {
                            @Model.Curso.Carrera.Nombre
                        }
                        else
                        {
                            <span class="text-muted">
                                Carrera no disponible
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.FechaMatricula)
                    </dt>

                    <dd class="col-sm-8">
                        @Model.FechaMatricula.ToString("dd/MM/yyyy")
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.PeriodoAcademico)
                    </dt>

                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.PeriodoAcademico)
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.Estado)
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.Estado == "Activa")
                        {
                            <span class="badge bg-success">
                                Activa
                            </span>
                        }
                        else if (Model.Estado == "Finalizada")
                        {
                            <span class="badge bg-primary">
                                Finalizada
                            </span>
                        }
                        else if (Model.Estado == "Cancelada")
                        {
                            <span class="badge bg-danger">
                                Cancelada
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                @Model.Estado
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.NotaFinal)
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.NotaFinal.HasValue)
                        {
                            @Model.NotaFinal.Value.ToString("0.##")
                        }
                        else
                        {
                            <span class="text-muted">
                                Pendiente
                            </span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit"
                                class="btn btn-danger">
                            Confirmar eliminación
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>