@model ProyectoFinal.Models.Curso

@{
    ViewData["Title"] = "Editar curso";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h2 class="mb-0">Editar curso</h2>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    Modifique la información del curso seleccionado.
                </p>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Codigo"
                               class="form-label">
                        </label>

                        <input asp-for="Codigo"
                               class="form-control" />

                        <span asp-validation-for="Codigo"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nombre"
                               class="form-label">
                        </label>

                        <input asp-for="Nombre"
                               class="form-control" />

                        <span asp-validation-for="Nombre"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CarreraId"
                               class="form-label">
                        </label>

                        <select asp-for="CarreraId"
                                class="form-select"
                                asp-items="ViewBag.CarreraId">
                            <option value="">
                                Seleccione una carrera
                            </option>
                        </select>

                        <span asp-validation-for="CarreraId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Creditos"
                                   class="form-label">
                            </label>

                            <input asp-for="Creditos"
                                   class="form-control"
                                   type="number"
                                   min="1"
                                   max="10" />

                            <span asp-validation-for="Creditos"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CupoMaximo"
                                   class="form-label">
                            </label>

                            <input asp-for="CupoMaximo"
                                   class="form-control"
                                   type="number"
                                   min="1"
                                   max="100" />

                            <span asp-validation-for="CupoMaximo"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Activo"
                               class="form-check-input" />

                        <label asp-for="Activo"
                               class="form-check-label">
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-warning">
                            Guardar cambios
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}