@model ProyectoFinal.Models.Carrera

@{
    ViewData["Title"] = "Agregar carrera";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Agregar carrera</h2>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    Complete la información para registrar una nueva carrera.
                </p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Codigo" class="form-label"></label>

                        <input asp-for="Codigo"
                               class="form-control"
                               placeholder="Ejemplo: IS-001" />

                        <span asp-validation-for="Codigo"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>

                        <input asp-for="Nombre"
                               class="form-control"
                               placeholder="Ejemplo: Ingeniería en Sistemas" />

                        <span asp-validation-for="Nombre"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label"></label>

                        <textarea asp-for="Descripcion"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Ingrese una breve descripción de la carrera">
                        </textarea>

                        <span asp-validation-for="Descripcion"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Activa"
                               class="form-check-input" />

                        <label asp-for="Activa"
                               class="form-check-label">
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            Guardar carrera
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}